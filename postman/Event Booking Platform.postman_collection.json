{
  "info": {
    "name": "Event Booking Platform",
    "description": "Postman collection for the MERN Event Booking Platform backend APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.environment.set('token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.environment.set('token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "Upload Avatar",
          "request": {
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "avatar",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": "{{baseUrl}}/api/auth/avatar"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"password1234\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/password"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Public Events",
      "item": [
        {
          "name": "List Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/events?limit=12"
          }
        },
        {
          "name": "Search Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/events?search=music&category=Music&city=Mumbai"
          }
        },
        {
          "name": "Get Event By ID Or Slug",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/events/{{eventSlug}}"
          }
        },
        {
          "name": "Get Event Seats",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/events/{{eventId}}/seats"
          }
        }
      ]
    },
    {
      "name": "Contact",
      "item": [
        {
          "name": "Create Contact Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.contactMessage?._id) pm.environment.set('contactMessageId', json.contactMessage._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"user@example.com\",\n  \"category\": \"booking\",\n  \"subject\": \"Ticket delivery question\",\n  \"message\": \"I need help finding my booking confirmation email.\"\n}"
            },
            "url": "{{baseUrl}}/api/contact"
          }
        }
      ]
    },
    {
      "name": "Admin Events",
      "item": [
        {
          "name": "Manage Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/events/admin/manage"
          }
        },
        {
          "name": "Upload Event Poster",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "poster",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": "{{baseUrl}}/api/events/poster"
          }
        },
        {
          "name": "Create Event",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.event?._id) pm.environment.set('eventId', json.event._id);",
                  "if (json.event?.slug) pm.environment.set('eventSlug', json.event.slug);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Neon Nights Live\",\n  \"description\": \"A high-energy live music event with curated performances and reserved seating.\",\n  \"category\": \"Music\",\n  \"venue\": {\n    \"name\": \"Jio World Garden\",\n    \"address\": \"Bandra Kurla Complex\",\n    \"city\": \"Mumbai\"\n  },\n  \"startsAt\": \"2026-08-20T14:30:00.000Z\",\n  \"priceFrom\": 999,\n  \"totalSeats\": 30,\n  \"status\": \"draft\"\n}"
            },
            "url": "{{baseUrl}}/api/events"
          }
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Neon Nights Live Updated\",\n  \"priceFrom\": 1199\n}"
            },
            "url": "{{baseUrl}}/api/events/{{eventId}}"
          }
        },
        {
          "name": "Publish Event",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": "{{baseUrl}}/api/events/{{eventId}}/publish"
          }
        },
        {
          "name": "Cancel Event",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": "{{baseUrl}}/api/events/{{eventId}}/cancel"
          }
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/events/{{eventId}}"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Lock Seat",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"seatNumber\": \"{{seatNumber}}\"\n}"
            },
            "url": "{{baseUrl}}/api/bookings/lock-seat"
          }
        },
        {
          "name": "Release Seat",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"seatNumber\": \"{{seatNumber}}\"\n}"
            },
            "url": "{{baseUrl}}/api/bookings/release-seat"
          }
        },
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.booking?._id) pm.environment.set('bookingId', json.booking._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"seatNumbers\": [\"{{seatNumber}}\"]\n}"
            },
            "url": "{{baseUrl}}/api/bookings"
          }
        },
        {
          "name": "My Bookings",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/bookings/my"
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/admin/dashboard"
          }
        },
        {
          "name": "List Contact Messages",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.contactMessages?.[0]?._id) pm.environment.set('contactMessageId', json.contactMessages[0]._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/admin/contact-messages?page=1&limit=20"
          }
        },
        {
          "name": "Update Contact Message Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/contact-messages/{{contactMessageId}}/status"
          }
        },
        {
          "name": "List Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.users?.[0]?._id) pm.environment.set('userId', json.users[0]._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/admin/users?page=1&limit=20"
          }
        },
        {
          "name": "Update User Role",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"user\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/users/{{userId}}/role"
          }
        },
        {
          "name": "Update User Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": true\n}"
            },
            "url": "{{baseUrl}}/api/admin/users/{{userId}}/status"
          }
        }
      ]
    }
  ]
}
