NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

MONGO_URI=mongodb://127.0.0.1:27017/event_booking_platform

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
COOKIE_EXPIRES_DAYS=7

REDIS_URL=redis://127.0.0.1:6379
SEAT_LOCK_TTL_SECONDS=600
CACHE_TTL_SECONDS=300

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=event-booking-platform

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Ticketo <no-reply@example.com>

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
BOOKING_RATE_LIMIT_WINDOW_MS=60000
BOOKING_RATE_LIMIT_MAX=5

MULTER_FILE_SIZE_MB=5
QR_CODE_BASE_URL=http://localhost:5173/tickets
